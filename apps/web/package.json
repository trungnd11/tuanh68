{
  "name": "@tuanh68/landing-page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:sit": "dotenv -e .env.sit -- next dev",
    "dev:ida": "dotenv -e .env.ida -- next dev",
    "dev:prod": "dotenv -e .env.production -- next dev",
    "build": "dotenv -e .env -- next build && node scripts/copy-standalone-assets.mjs",
    "build:sit": "dotenv -e .env.sit -- next build && node scripts/copy-standalone-assets.mjs",
    "build:ida": "dotenv -e .env.ida -- next build && node scripts/copy-standalone-assets.mjs",
    "build:prod": "dotenv -e .env.production -- next build && node scripts/copy-standalone-assets.mjs",
    "start": "node .next/standalone/server.js",
    "start:sit": "dotenv -e .env.sit -- node .next/standalone/server.js",
    "start:ida": "dotenv -e .env.ida -- node .next/standalone/server.js",
    "start:prod": "dotenv -e .env.production -- node .next/standalone/server.js",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@squircle-js/react": "^1.3.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-animations": "^1.0.0",
    "react-dom": "19.2.4",
    "react-intersection-observer": "^10.0.3",
    "react-twc": "^1.5.1",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-animations": "^1.0.3",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
}
