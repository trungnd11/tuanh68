{
  "extends": "@tuanh68/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@tuanh68/types": [
        "../../packages/types/src/index.ts"
      ],
      "@tuanh68/schemas": [
        "../../packages/schemas/src/index.ts"
      ],
      "@tuanh68/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@tuanh68/ui": [
        "../../packages/ui/src/index.ts"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "tailwind.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
